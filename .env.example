# Neo4j (matches the keys in the AuraDB .txt download)
NEO4J_URI=bolt://localhost:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=devpassword
NEO4J_DATABASE=neo4j

# OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Graphiti
GRAPHITI_NAMESPACE=default

# LangSmith (developer-only — agent tracing).
# Leave LANGSMITH_API_KEY blank to disable tracing entirely.
# When the key is set, the backend probes LangSmith at startup; if the
# probe fails, LANGSMITH_TRACING is forced off for this process.
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=multiagent_graphrag_dev
LANGSMITH_TRACING=false
LANGSMITH_ENDPOINT=https://api.smith.langchain.com
